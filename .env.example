# ==============================================
# InteligenciaGeopolitica — Configuración
# ==============================================
# Copia este archivo a .env y ajusta los valores.

# --- LLM (Modelo de lenguaje) ---
# Opciones: ollama | openai | auto (ollama con fallback a openai)
LLM_PROVIDER=ollama

# Ollama (instalación local — ver setup.sh)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=atalaya-geoint

# OpenAI (solo necesario si LLM_PROVIDER=openai o LLM_PROVIDER=auto)
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# OPENAI_MODEL=gpt-4o-mini

# --- Proveedores de noticias opcionales ---
# NewsAPI (gratis en https://newsapi.org — 100 req/día)
# NEWSAPI_KEY=your_newsapi_key_here
